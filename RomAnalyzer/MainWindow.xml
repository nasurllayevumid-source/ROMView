<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RomAnalyzer.ViewModels"
        x:Class="RomAnalyzer.MainWindow"
        Title="ROM Analyzer"
        Width="600"
        Height="450"
        MinWidth="500"
        MinHeight="400"
        Background="#1a1a2e"
        AllowDrop="True"
        DragDrop.Drop="OnDrop">

  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>

  <DockPanel>
    <Menu DockPanel.Dock="Top" Background="#16213e">
      <MenuItem Header="File">
        <MenuItem Header="Open ROM..." Command="{Binding OpenCommand}" />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
      </MenuItem>
    </Menu>

    <Border Background="#0f0f23" Padding="20">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="10">
          <TextBlock Text="🔍 ROM Analyzer" FontSize="24" FontWeight="Bold" Foreground="#e94560" />
          <TextBlock Text="{Binding Status}" Foreground="#aaa" FontSize="14" />
        </StackPanel>

        <Border Background="#16213e" CornerRadius="10" Padding="15" Margin="0,20,0,0">
          <StackPanel Spacing="8" IsVisible="{Binding CurrentRom, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding CurrentRom.FileName}" FontSize="18" FontWeight="Bold" Foreground="White" />
            <TextBlock Text="Type:" Foreground="#888" />
            <TextBlock Text="{Binding CurrentRom.RomType}" Foreground="#4ade80" />
            <TextBlock Text="Size:" Foreground="#888" />
            <TextBlock Text="{Binding CurrentRom.FileSizeFormatted}" Foreground="#facc15" />
            <TextBlock Text="Header Info:" Foreground="#888" />
            <TextBlock Text="{Binding CurrentRom.HeaderInfo}" Foreground="#60a5fa" />
            <TextBlock Text="CRC32:" Foreground="#888" />
            <TextBlock Text="{Binding CurrentRom.Crc32}" Foreground="#f472b6" />
            <TextBlock Text="SHA1:" Foreground="#888" />
            <TextBlock Text="{Binding CurrentRom.Sha1}" Foreground="#f472b6" FontSize="11" />
          </StackPanel>
        </Border>

        <Border Background="#16213e" CornerRadius="10" Padding="15" Margin="0,10,0,0">
          <TextBlock Text="📂 Drag & Drop a ROM file here" Foreground="#555" FontSize="14" HorizontalAlignment="Center" />
        </Border>
      </DockPanel>
    </Border>
  </DockPanel>
</Window>